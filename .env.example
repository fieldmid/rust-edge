# PowerSync connection (required)
POWERSYNC_URL=https://YOUR_POWERSYNC_INSTANCE.powersync.journeyapps.com
POWERSYNC_TOKEN=YOUR_POWERSYNC_JWT

# Optional stream subscription for scoped monitoring
POWERSYNC_STREAM=edge_critical_feed
POWERSYNC_STREAM_PARAMS={"site_id":"de8be632-fc8d-4704-9a5e-5494de1eb6fd"}

# Local daemon identity/storage
DEVICE_ID=fieldmid-edge-001
FIELDMID_DB_PATH=fieldmid-edge.db
